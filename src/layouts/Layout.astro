---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { useTranslations, type Lang } from '../i18n/translations';

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
}

const { title = 'ReformIt', description, lang = 'hu' } = Astro.props;
const t = useTranslations(lang);

const defaultDesc = lang === 'hu'
  ? 'Magyar webfejlesztő ügynökség: egyedi weboldalak, webalkalmazások, modern technológiákkal.'
  : 'Hungarian web development agency: custom websites and web applications with modern technologies.';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? defaultDesc} />
    <meta name="robots" content="index, follow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    {lang === 'hu' && <link rel="alternate" hreflang="en" href="/en" />}
    {lang === 'en' && <link rel="alternate" hreflang="hu" href="/" />}
    <title>{title} | ReformIt</title>
  </head>
  <body class="relative">
    <!-- Fixed grid only -->
    <div class="fixed inset-0 z-0 pointer-events-none bg-[url('/grid.svg')] opacity-[0.04]"></div>
    <!-- Scrolling orbs (randomised on each load via JS) -->
    <div id="orb-layer" class="absolute inset-0 z-0 pointer-events-none overflow-hidden"></div>
    <Nav lang={lang} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
    <script>
      // Random orbs — stratified distribution
      (function () {
        const layer = document.getElementById('orb-layer');
        if (!layer) return;

        const MIN = 6, MAX = 12;
        const colors = ['#6272f1','#7c3aed','#4f46e5','#8b5cf6','#6d28d9','#4338ca'];
        const count  = MIN + Math.floor(Math.random() * (MAX - MIN + 1));
        const pageH  = document.documentElement.scrollHeight;

        // Horizontal zones: left-bleed | center-left | center-right | right-bleed
        // Each orb is assigned a zone in round-robin order, then placed randomly within it.
        // Zones defined as [minLeft%, maxLeft%] where left% is the orb center's x position.
        const zones = [
          [-15, 15],   // bleeds off left edge
          [20,  45],   // left-center
          [50,  75],   // right-center
          [75, 105],   // bleeds off right edge
        ];

        for (let i = 0; i < count; i++) {
          // Vertical: first orb is always in the first viewport, rest fill the page evenly
          let top;
          if (i === 0) {
            top = Math.random() * window.innerHeight;
          } else {
            const remainingH = pageH - window.innerHeight;
            const bandH = remainingH / (count - 1);
            top = window.innerHeight + bandH * (i - 1) + Math.random() * bandH;
          }

          // Horizontal: cycle through zones so no side is neglected
          const zone   = zones[i % zones.length];
          const size   = 280 + Math.random() * 380;        // 280–660 px
          const left   = zone[0] + Math.random() * (zone[1] - zone[0]);
          const opacity = 0.07 + Math.random() * 0.11;     // 0.07–0.18
          const color  = colors[Math.floor(Math.random() * colors.length)];

          const el = document.createElement('div');
          el.style.cssText = [
            'position:absolute',
            'border-radius:50%',
            'filter:blur(80px)',
            'pointer-events:none',
            `width:${size}px`,
            `height:${size}px`,
            `top:${top}px`,
            `left:${left}%`,
            `opacity:${opacity}`,
            `background:${color}`,
          ].join(';');
          layer.appendChild(el);
        }
      })();

      // Intersection Observer for reveal animations
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
