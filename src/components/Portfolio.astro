---
import { useTranslations, type Lang } from '../i18n/translations';
import projectsData from '../data/projects.json';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const iconSvgs: Record<string, string> = {
  shop: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>`,
  chart: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="2" y1="20" x2="22" y2="20"/></svg>`,
  building: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="9" y1="22" x2="9" y2="12"/><line x1="15" y1="22" x2="15" y2="12"/><path d="M9 12h6"/><path d="M9 7h1"/><path d="M14 7h1"/><path d="M9 2v2"/><path d="M15 2v2"/></svg>`,
  medical: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
  music: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>`,
  leaf: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>`,
  utensils: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></svg>`,
  coffee: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/><line x1="6" y1="2" x2="6" y2="4"/><line x1="10" y1="2" x2="10" y2="4"/><line x1="14" y1="2" x2="14" y2="4"/></svg>`,
};

const tagColors: Record<string, string> = {
  frontend: 'bg-brand-900/60 text-brand-300 border-brand-700/50',
  fullstack: 'bg-violet-900/60 text-violet-300 border-violet-700/50',
  ecommerce: 'bg-amber-900/60 text-amber-300 border-amber-700/50',
  webapp: 'bg-green-900/60 text-green-300 border-green-700/50',
};

const projects = projectsData.projects;
---

<section id="portfolio" class="section-padding relative overflow-hidden">

  <div class="max-w-7xl mx-auto relative">

    <!-- Header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass text-sm font-medium text-brand-300 mb-4 reveal">
        {t('portfolio.badge')}
      </div>
      <h2 class="text-4xl sm:text-5xl font-extrabold text-white mb-4 reveal reveal-delay-1">
        {t('portfolio.title')}&nbsp;<span class="gradient-text">{t('portfolio.title.accent')}</span>
      </h2>
      <p class="text-slate-400 text-lg max-w-xl mx-auto reveal reveal-delay-2">
        {t('portfolio.description')}
      </p>
    </div>

    <!-- Projects grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map(({ title, desc, tags, color, iconType, image, url, year }, i) => (
        <article class={`reveal reveal-delay-${(i % 3) + 1} group glass rounded-2xl overflow-hidden hover:-translate-y-1 hover:bg-white/[0.07] transition-all duration-300`}>

          <!-- Card header: image if available, else gradient with icon -->
          {image ? (
            <div class="relative h-48 overflow-hidden">
              <img
                src={image}
                alt={title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
              <div class="absolute top-4 right-4 text-white/60 text-xs font-mono">{year}</div>
            </div>
          ) : (
            <div class={`relative h-40 bg-gradient-to-br ${color} flex items-center justify-center overflow-hidden`}>
              <div class="absolute inset-0 bg-black/20"></div>
              <div class="absolute top-0 right-0 w-32 h-32 bg-white/10 rounded-full blur-2xl"></div>
              <div class="text-white relative z-10 group-hover:scale-110 transition-transform duration-300 opacity-90">
                <Fragment set:html={iconSvgs[iconType] ?? iconSvgs.shop} />
              </div>
              <div class="absolute top-4 right-4 text-white/50 text-xs font-mono">{year}</div>
            </div>
          )}

          <!-- Card body -->
          <div class="p-6">
            <div class="flex items-start justify-between mb-2">
              <h3 class="text-white font-bold text-lg">{title}</h3>
              {url && (
                <a
                  href={url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-brand-400 hover:text-brand-300 transition-colors flex-shrink-0 ml-2"
                  aria-label={`${title} live site`}
                >
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                </a>
              )}
            </div>

            <!-- Tags -->
            <div class="flex flex-wrap gap-1.5 mb-3">
              {tags.map((tag: string) => (
                <span class={`px-2.5 py-0.5 rounded-full text-xs font-medium border ${tagColors[tag]}`}>
                  {t(`portfolio.tag.${tag}` as any)}
                </span>
              ))}
            </div>

            <p class="text-slate-400 text-sm leading-relaxed">
              {lang === 'hu' ? desc.hu : desc.en}
            </p>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>
