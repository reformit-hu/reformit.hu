---
import { useTranslations, type Lang } from '../i18n/translations';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="contact" class="section-padding relative overflow-hidden">

  <div class="max-w-7xl mx-auto relative">

    <!-- Header -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass text-sm font-medium text-brand-300 mb-4 reveal">
        {t('contact.badge')}
      </div>
      <h2 class="text-4xl sm:text-5xl font-extrabold text-white mb-4 reveal reveal-delay-1">
        {t('contact.title')}<br />
        <span class="gradient-text">{t('contact.title.accent')}</span>
      </h2>
      <p class="text-slate-400 text-lg max-w-xl mx-auto reveal reveal-delay-2">
        {t('contact.description')}
      </p>
    </div>

    <div class="grid lg:grid-cols-5 gap-10 items-start">

      <!-- Info cards -->
      <div class="lg:col-span-2 space-y-4 reveal reveal-delay-1">

        <a href="mailto:hello@reformit.hu" class="flex items-center gap-4 glass rounded-2xl p-5 hover:bg-white/[0.07] transition-all duration-200 group">
          <div class="w-12 h-12 rounded-xl gradient-bg flex items-center justify-center flex-shrink-0 group-hover:scale-105 transition-transform">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </div>
          <div>
            <div class="text-xs text-slate-500 uppercase tracking-wider mb-0.5">Email</div>
            <div class="text-white font-medium">{t('contact.info.email')}</div>
          </div>
        </a>

        <div class="flex items-center gap-4 glass rounded-2xl p-5">
          <div class="w-12 h-12 rounded-xl gradient-bg flex items-center justify-center flex-shrink-0">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <div class="text-xs text-slate-500 uppercase tracking-wider mb-0.5">Helyszín</div>
            <div class="text-white font-medium">{t('contact.info.location')}</div>
          </div>
        </div>

        <!-- Response time badge -->
        <div class="glass rounded-2xl p-5 flex items-center gap-3">
          <div class="w-3 h-3 rounded-full bg-green-400 animate-pulse flex-shrink-0"></div>
          <p class="text-slate-300 text-sm">
            {lang === 'hu' ? 'Általában 24 órán belül válaszolunk.' : 'We usually respond within 24 hours.'}
          </p>
        </div>
      </div>

      <!-- Form -->
      <form
        id="contact-form"
        class="lg:col-span-3 glass rounded-3xl p-8 reveal reveal-delay-2"
        novalidate
      >
        <div class="grid sm:grid-cols-2 gap-5 mb-5">
          <div>
            <label class="block text-sm font-medium text-slate-300 mb-2">{t('contact.name')}</label>
            <input
              type="text"
              name="name"
              placeholder={t('contact.name.placeholder')}
              required
              class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-slate-500 text-sm focus:outline-none focus:border-brand-500/60 focus:bg-white/8 transition-all duration-200"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-300 mb-2">{t('contact.email')}</label>
            <input
              type="email"
              name="email"
              placeholder={t('contact.email.placeholder')}
              required
              class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-slate-500 text-sm focus:outline-none focus:border-brand-500/60 focus:bg-white/8 transition-all duration-200"
            />
          </div>
        </div>

        <div class="mb-6">
          <label class="block text-sm font-medium text-slate-300 mb-2">{t('contact.project')}</label>
          <textarea
            name="message"
            rows="5"
            placeholder={t('contact.project.placeholder')}
            required
            class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-slate-500 text-sm focus:outline-none focus:border-brand-500/60 focus:bg-white/8 transition-all duration-200 resize-none"
          ></textarea>
        </div>

        <button
          id="submit-btn"
          type="submit"
          class="w-full py-3.5 rounded-xl text-base font-semibold gradient-bg text-white hover:opacity-90 transition-opacity duration-200 glow flex items-center justify-center gap-2 group disabled:opacity-60 disabled:cursor-not-allowed"
        >
          <!-- Normal state -->
          <span id="btn-text" class="flex items-center gap-2">
            {t('contact.submit')}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform duration-200">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </span>
          <!-- Loading spinner -->
          <span id="btn-spinner" class="hidden flex items-center gap-2">
            <svg class="animate-spin" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
            </svg>
            {lang === 'hu' ? 'Küldés...' : 'Sending...'}
          </span>
        </button>

        <!-- Success message -->
        <div id="form-success" class="hidden mt-4 p-4 rounded-xl bg-green-500/10 border border-green-500/30 text-green-400 text-sm text-center">
          {lang === 'hu' ? 'Üzeneted megkaptuk! Hamarosan felvesszük veled a kapcsolatot.' : 'Message received! We\'ll be in touch soon.'}
        </div>

        <!-- Error message -->
        <div id="form-error" class="hidden mt-4 p-4 rounded-xl bg-red-500/10 border border-red-500/30 text-red-400 text-sm text-center">
          {lang === 'hu' ? 'Hiba történt az üzenet küldésekor. Kérjük, próbáld újra, vagy írj közvetlenül a hello@reformit.hu címre.' : 'Something went wrong. Please try again or email us directly at hello@reformit.hu.'}
        </div>
      </form>
    </div>
  </div>
</section>

<script>
  const EMAIL_API = 'https://emailing-service.botond-balla.workers.dev/send';
  const API_KEY   = import.meta.env.PUBLIC_EMAIL_API_KEY ?? '';

  const form       = document.getElementById('contact-form')  as HTMLFormElement;
  const btn        = document.getElementById('submit-btn')    as HTMLButtonElement;
  const btnText    = document.getElementById('btn-text')      as HTMLSpanElement;
  const btnSpinner = document.getElementById('btn-spinner')   as HTMLElement;
  const msgSuccess = document.getElementById('form-success')  as HTMLElement;
  const msgError   = document.getElementById('form-error')    as HTMLElement;

  function setLoading(loading: boolean) {
    btn.disabled = loading;
    btnText.classList.toggle('hidden', loading);
    btnSpinner.classList.toggle('hidden', !loading);
  }

  const HEADERS = {
    'Content-Type': 'application/json',
    'X-API-Key': API_KEY,
  };

  function sendEmail(payload: object) {
    return fetch(EMAIL_API, {
      method: 'POST',
      headers: HEADERS,
      body: JSON.stringify(payload),
    }).then(r => r.json() as Promise<{ success?: boolean; error?: string }>);
  }

  // --- Internal notification email (to ReformIt) ---
  function buildInternalHtml(name: string, email: string, message: string) {
    return `
<!DOCTYPE html>
<html lang="hu">
<head><meta charset="UTF-8" /></head>
<body style="margin:0;padding:0;background:#0a0a0f;font-family:Inter,Arial,sans-serif;color:#e2e8f0;">
  <div style="max-width:560px;margin:40px auto;background:#111118;border-radius:16px;overflow:hidden;border:1px solid rgba(255,255,255,0.08);">
    <div style="background:linear-gradient(135deg,#4060FF,#8833EE);padding:32px 32px 24px;">
      <img src="https://reformit.hu/logo.svg" alt="ReformIt" height="28" style="margin-bottom:12px;" />
      <h1 style="margin:0;font-size:22px;font-weight:800;color:#fff;">Új üzenet érkezett</h1>
      <p style="margin:6px 0 0;font-size:14px;color:rgba(255,255,255,0.75);">reformit.hu kapcsolatfelvételi űrlap</p>
    </div>
    <div style="padding:32px;">
      <table style="width:100%;border-collapse:collapse;">
        <tr>
          <td style="padding:10px 0;color:#94a3b8;font-size:13px;width:110px;vertical-align:top;">Név</td>
          <td style="padding:10px 0;color:#f1f5f9;font-size:14px;font-weight:600;">${name}</td>
        </tr>
        <tr>
          <td style="padding:10px 0;color:#94a3b8;font-size:13px;vertical-align:top;">E-mail</td>
          <td style="padding:10px 0;"><a href="mailto:${email}" style="color:#818cf8;font-size:14px;">${email}</a></td>
        </tr>
        <tr>
          <td colspan="2" style="padding-top:20px;">
            <div style="color:#94a3b8;font-size:13px;margin-bottom:8px;">Üzenet</div>
            <div style="background:rgba(255,255,255,0.04);border-radius:10px;padding:16px;color:#e2e8f0;font-size:14px;line-height:1.7;white-space:pre-wrap;">${message}</div>
          </td>
        </tr>
      </table>
      <div style="margin-top:28px;padding-top:20px;border-top:1px solid rgba(255,255,255,0.06);font-size:12px;color:#475569;text-align:center;">
        ReformIt · reformit.hu · hello@reformit.hu
      </div>
    </div>
  </div>
</body>
</html>`;
  }

  // --- Confirmation email (to the sender) ---
  function buildConfirmationHtml(name: string, message: string) {
    return `
<!DOCTYPE html>
<html lang="hu">
<head><meta charset="UTF-8" /></head>
<body style="margin:0;padding:0;background:#f8fafc;font-family:Inter,Arial,sans-serif;color:#1e293b;">
  <div style="max-width:560px;margin:40px auto;background:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.08);">

    <!-- Header -->
    <div style="background:linear-gradient(135deg,#4060FF,#8833EE);padding:40px 32px 32px;text-align:center;">
      <img src="https://reformit.hu/logo.svg" alt="ReformIt" height="36" style="margin-bottom:16px;" />
      <h1 style="margin:0;font-size:24px;font-weight:800;color:#fff;letter-spacing:-0.5px;">Megkaptuk az üzeneted!</h1>
      <p style="margin:10px 0 0;font-size:15px;color:rgba(255,255,255,0.8);">Hamarosan felvesszük veled a kapcsolatot.</p>
    </div>

    <!-- Body -->
    <div style="padding:36px 32px;">
      <p style="margin:0 0 16px;font-size:15px;line-height:1.7;color:#334155;">
        Szia <strong>${name}</strong>,
      </p>
      <p style="margin:0 0 16px;font-size:15px;line-height:1.7;color:#334155;">
        Köszönjük, hogy megkerestél minket! Üzenetedet megkaptuk, és <strong>24 órán belül</strong> visszajelzünk.
      </p>

      <!-- Message recap -->
      <div style="background:#f1f5f9;border-left:3px solid #6272f1;border-radius:0 10px 10px 0;padding:16px 20px;margin:24px 0;">
        <div style="font-size:12px;color:#94a3b8;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:8px;">Az üzeneted</div>
        <div style="font-size:14px;color:#475569;line-height:1.7;white-space:pre-wrap;">${message}</div>
      </div>

      <p style="margin:24px 0 0;font-size:14px;line-height:1.7;color:#64748b;">
        Ha sürgős kérdésed van, írj közvetlenül a
        <a href="mailto:hello@reformit.hu" style="color:#6272f1;text-decoration:none;font-weight:600;">hello@reformit.hu</a>
        címre.
      </p>
    </div>

    <!-- Footer -->
    <div style="background:#f8fafc;padding:20px 32px;border-top:1px solid #e2e8f0;text-align:center;">
      <p style="margin:0;font-size:12px;color:#94a3b8;">
        &copy; 2026 ReformIt &middot;
        <a href="https://reformit.hu" style="color:#6272f1;text-decoration:none;">reformit.hu</a>
      </p>
      <p style="margin:6px 0 0;font-size:11px;color:#cbd5e1;">
        Ezt az e-mailt azért kaptad, mert kitöltötted a kapcsolatfelvételi űrlapunkat.
      </p>
    </div>

  </div>
</body>
</html>`;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    msgSuccess.classList.add('hidden');
    msgError.classList.add('hidden');

    const data    = new FormData(form);
    const name    = (data.get('name')    as string).trim();
    const email   = (data.get('email')   as string).trim();
    const message = (data.get('message') as string).trim();

    if (!name || !email || !message) return;

    setLoading(true);

    try {
      const [internal, confirmation] = await Promise.all([
        sendEmail({
          subject: `Új üzenet a reformit.hu-ról – ${name}`,
          replyTo: email,
          html:    buildInternalHtml(name, email, message),
          text:    `Feladó: ${name} <${email}>\n\n${message}`,
        }),
        sendEmail({
          to:      email,
          subject: 'Megkaptuk az üzeneted – ReformIt',
          html:    buildConfirmationHtml(name, message),
          text:    `Szia ${name},\n\nKöszönjük, hogy megkerestél minket! Üzenetedet megkaptuk, és 24 órán belül visszajelzünk.\n\nAz üzeneted:\n${message}\n\nÜdvözlettel,\nA ReformIt csapata\nhello@reformit.hu`,
        }),
      ]);

      if (internal.success) {
        msgSuccess.classList.remove('hidden');
        form.reset();
      } else {
        throw new Error(internal.error ?? 'Unknown error');
      }

      if (!confirmation.success) {
        console.warn('Confirmation email failed:', confirmation.error);
      }
    } catch (err) {
      console.error('Email send failed:', err);
      msgError.classList.remove('hidden');
    } finally {
      setLoading(false);
    }
  });
</script>
